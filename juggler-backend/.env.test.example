# juggler-backend/.env.test.example
# Copy to .env.test and fill in real values before running calendar sync integration tests.
# .env.test is gitignored — never commit it.
#
# Requires: cd test-bed && make up  (test DB on port 3407)

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3407
DB_USER=root
DB_PASSWORD=rootpass
DB_NAME=juggler

# ── Auth / Redis (Docker test infra) ─────────────────────────────────────────
AUTH_URL=localhost:5110
REDIS_HOST=localhost
REDIS_PORT=6479

# Credential encryption key (64-char hex, 32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=<64-char-hex>

# ── Google Calendar ───────────────────────────────────────────────────────────
# OAuth client from Google Cloud Console (same app as dev).
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
# Refresh token for the test Google account.
# Get via: node scripts/get-gcal-refresh-token.js  (or reuse dev account token)
TEST_GCAL_REFRESH_TOKEN=<your-gcal-refresh-token>

# ── Microsoft Calendar ────────────────────────────────────────────────────────
# App registration from Azure portal (same app as dev).
MICROSOFT_CLIENT_ID=<your-msft-client-id>
MICROSOFT_CLIENT_SECRET=<your-msft-client-secret>
MSFT_CAL_REDIRECT_URI=http://localhost:5002/api/msft-cal/callback
# Refresh token for the test Microsoft account.
# Get via: run the MSFT OAuth flow in the app and copy the stored refresh token from the DB.
TEST_MSFT_REFRESH_TOKEN=<your-msft-refresh-token>

# ── Apple Calendar (CalDAV / iCloud) ──────────────────────────────────────────
# Use a PERSONAL or JUGGLER-SPECIFIC calendar — NOT the Family Calendar.
# (Family Calendar events are visible to all family members; test events would appear there.)
#
# How to find your calendar URL:
#   1. In iCloud.com → Calendar, right-click the target calendar → "Copy CalDAV link"
#      The URL looks like: https://p01-caldav.icloud.com/<apple-id-number>/calendars/<uuid>/
#   2. Or: connect Apple Calendar in the juggler UI and copy apple_cal_calendar_url from DB.
#
TEST_APPLE_USERNAME=<your-icloud-apple-id-email>
# Use an app-specific password (appleid.apple.com → Security → App-Specific Passwords).
# Plain text here — test-setup.js will encrypt it on the way into the DB.
TEST_APPLE_PASSWORD=<app-specific-password>
TEST_APPLE_CALENDAR_URL=<your-personal-caldav-calendar-url>
# Optional — defaults to https://caldav.icloud.com
# TEST_APPLE_SERVER_URL=https://caldav.icloud.com

# Set to 1 to run the live calendar-API integration tests (tests/cal-sync/*).
# Requires valid TEST_GCAL/MSFT/APPLE creds below. Default unset = those tests SKIP
# (offline-safe). Without this flag a stale token no longer makes them FAIL.
RUN_LIVE_CALENDAR_TESTS=
