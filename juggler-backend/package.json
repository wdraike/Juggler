{
  "name": "juggler-backend",
  "version": "1.0.0",
  "description": "Juggler task tracker backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "npx nodemon src/server.js",
    "migrate": "node scripts/migrate-guard.js migrate:latest",
    "migrate:rollback": "node scripts/migrate-guard.js migrate:rollback",
    "migrate:status": "npx knex migrate:status",
    "db:validate": "node scripts/db-validate.js",
    "test": "jest --forceExit --runInBand",
    "test:adapter": "node scripts/test-adapter.js",
    "verify-sync": "node ../shared/verify-sync.js",
    "audit:knip": "knip --reporter json 2>/dev/null | sed -n '/^[\\[{]/,$p' > ../../.planning/phases/juggler-code-review/baseline/knip-backend.json || true",
    "audit:depcheck": "depcheck --json 2>/dev/null | sed -n '/^[\\[{]/,$p' > ../../.planning/phases/juggler-code-review/baseline/depcheck-backend.json || true",
    "audit:unused": "eslint 'src/**/*.js' --rule '{\"unused-imports/no-unused-imports\":\"error\",\"unused-imports/no-unused-vars\":\"error\"}' --format json --output-file ../../.planning/phases/juggler-code-review/baseline/eslint-unused-backend.json || true",
    "lint": "eslint 'src/**/*.js'",
    "lint:boundaries": "eslint --no-inline-config --config eslint.boundaries.config.js 'src/**/*.js'",
    "security:sql-scan": "node scripts/sql-injection-scanner.js",
    "security:lint": "eslint 'src/**/*.js' 'tests/**/*.js' 'scripts/**/*.js' --rule '{\"sql-injection/no-unsafe-sql\":\"error\"}' --config eslint-sql-injection-rules.js",
    "security:check": "npm run security:sql-scan && npm run security:lint",
    "precommit": "npm run lint:boundaries && npm run security:check && npm test"
  },
  "dependencies": {
    "@google-cloud/tasks": "^5.5.1",
    "@google/genai": "^1.46.0",
    "@grpc/grpc-js": "^1.10.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@raike/lib-db": "file:./vendor/lib-db",
    "@raike/lib-error-ingest": "file:./vendor/lib-error-ingest",
    "@raike/lib-logger": "file:./vendor/lib-logger",
    "auth-client": "file:../../auth-service/shared",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "google-auth-library": "^9.6.3",
    "helmet": "^8.1.0",
    "ical.js": "^2.2.1",
    "ioredis": "^5.10.1",
    "jose": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "lodash": "^4.18.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.9.2",
    "qs": "^6.15.2",
    "rate-limit-redis": "^4.3.1",
    "tsdav": "^2.1.8",
    "uuid": "^11.1.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ]
  },
  "overrides": {
    "uuid@<11.1.1": ">=11.1.1",
    "uuid": "^11.1.1",
    "qs": "^6.15.2",
    "lodash": "^4.18.0",
    "nodemailer": "^9.0.1",
    "shell-quote": "^1.8.4",
    "ws": "^8.21.0",
    "node-forge": "^1.4.0",
    "serialize-javascript": "^7.0.3",
    "fast-uri": "^3.1.2",
    "form-data": "^4.0.6",
    "multer": "^2.2.0",
    "underscore": "^1.13.8",
    "svgo": "^2.8.1",
    "linkify-it": "^5.0.1",
    "protobufjs": "^7.6.3",
    "hono": "^4.12.25",
    "follow-redirects": "^1.16.0",
    "picomatch": "^2.3.2",
    "brace-expansion": "^2.0.3",
    "http-proxy-middleware": "^2.0.10",
    "js-yaml": "^4.2.0",
    "launch-editor": "^2.14.1",
    "markdown-it": "^14.2.0",
    "@opentelemetry/core": "^2.8.0",
    "postcss": "^8.4.31",
    "react-router": "^6.30.4",
    "webpack-dev-server": "^5.2.5",
    "yaml": "^1.10.3",
    "nth-check": "^2.0.1",
    "ip-address": "^10.1.1",
    "tar": "^7.5.16",
    "dompurify": "^3.4.11",
    "path-to-regexp": "^0.1.13"
  }
}
