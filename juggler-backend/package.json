{
  "name": "juggler-backend",
  "version": "1.0.0",
  "description": "Juggler task tracker backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "npx nodemon src/server.js",
    "migrate": "node scripts/migrate-guard.js migrate:latest",
    "migrate:rollback": "node scripts/migrate-guard.js migrate:rollback",
    "migrate:status": "npx knex migrate:status",
    "test": "jest --forceExit",
    "test:adapter": "node scripts/test-adapter.js",
    "verify-sync": "node ../shared/verify-sync.js",
    "audit:knip": "knip --reporter json 2>/dev/null | sed -n '/^[\\[{]/,$p' > ../../.planning/phases/juggler-code-review/baseline/knip-backend.json || true",
    "audit:depcheck": "depcheck --json 2>/dev/null | sed -n '/^[\\[{]/,$p' > ../../.planning/phases/juggler-code-review/baseline/depcheck-backend.json || true",
    "audit:unused": "eslint 'src/**/*.js' --rule '{\"unused-imports/no-unused-imports\":\"error\",\"unused-imports/no-unused-vars\":\"error\"}' --format json --output-file ../../.planning/phases/juggler-code-review/baseline/eslint-unused-backend.json || true",
    "lint": "eslint 'src/**/*.js'",
    "lint:boundaries": "eslint --no-inline-config --config eslint.boundaries.config.js 'src/**/*.js'",
    "security:sql-scan": "node scripts/sql-injection-scanner.js",
    "security:lint": "eslint 'src/**/*.js' 'tests/**/*.js' 'scripts/**/*.js' --rule '{\"sql-injection/no-unsafe-sql\":\"error\"}' --config eslint-sql-injection-rules.js",
    "security:check": "npm run security:sql-scan && npm run security:lint",
    "precommit": "npm run lint:boundaries && npm run security:check && npm test"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@raike/lib-db": "file:./vendor/lib-db",
    "@raike/lib-error-ingest": "file:./vendor/lib-error-ingest",
    "@raike/lib-logger": "file:./vendor/lib-logger",
    "auth-client": "file:../../auth-service/shared",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "google-auth-library": "^9.6.3",
    "helmet": "^8.1.0",
    "ical.js": "^2.2.1",
    "ioredis": "^5.10.1",
    "jose": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.9.2",
    "rate-limit-redis": "^4.3.1",
    "tsdav": "^2.1.8",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ]
  },
  "overrides": {
    "uuid@<11.1.1": ">=11.1.1"
  }
}
