{
  "name": "juggler-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "axios": "^1.6.7",
    "bug-reporter-client": "file:../../bug-reporter-service/shared",
    "elkjs": "^0.11.1",
    "html2canvas": "^1.4.1",
    "juggler-shared": "file:../shared",
    "konva": "^9.3.6",
    "lucide-react": "^1.16.0",
    "mobile-drag-drop": "^3.0.0-rc.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.10",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-unused-imports": "^3.2.0",
    "http-proxy-middleware": "^2.0.6",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "audit:knip": "knip --reporter json 2>/dev/null | sed -n '/^[\\[{]/,$p' > ../../.planning/phases/juggler-code-review/baseline/knip-frontend.json || true",
    "audit:depcheck": "depcheck --json 2>/dev/null | sed -n '/^[\\[{]/,$p' > ../../.planning/phases/juggler-code-review/baseline/depcheck-frontend.json || true",
    "audit:unused": "eslint 'src/**/*.{js,jsx}' --rule '{\"unused-imports/no-unused-imports\":\"error\",\"unused-imports/no-unused-vars\":\"error\"}' --format json --output-file ../../.planning/phases/juggler-code-review/baseline/eslint-unused-frontend.json || true"
  },
  "jest": {
    "moduleNameMapper": {
      "^axios$": "<rootDir>/node_modules/axios/dist/node/axios.cjs",
      "^juggler-shared/(.*)$": "<rootDir>/../shared/$1.js"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "plugins": [
      "unused-imports"
    ],
    "rules": {
      "unused-imports/no-unused-imports": "error",
      "unused-imports/no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_"
        }
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
